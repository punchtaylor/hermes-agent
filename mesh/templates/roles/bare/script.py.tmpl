"""$service_name — minimal mesh node.

Auto-generated by `hermes mesh add $host --role bare`.
Publishes heartbeat + health to MQTT. Nothing else.

Topics:
  $namespace/$host/alive    — retained, every 30s, payload = ISO timestamp UTC
                              empty payload (LWT) = dead; last-writer-wins.
  $namespace/$host/health   — every 30s, payload = JSON {host, uptime, mem_used_pct, ts}

Edit this file in-place to extend behavior, or copy this role template
to ~/.hermes/mesh/roles/<new-name>/ and customize there.

NOTE on clean_session: this client uses default `clean_session=True`,
correct for heartbeat-only nodes that don't subscribe. Custom roles
that subscribe to topics need persistent state — set `clean_session=False`
when you copy this template for a subscribing role.
"""
from __future__ import annotations

import json
import os
import socket
import time
from datetime import datetime, timezone

import paho.mqtt.client as mqtt

NAMESPACE = "$namespace"
HOST = "$host"
BROKER = os.environ["MQTT_BROKER"]
USER = os.environ["MQTT_USER"]
PASSWORD = os.environ["MQTT_PASSWORD"]
CA_CERT = os.environ.get("MQTT_CA_CERT")  # optional; TLS if set
PORT = 8883 if CA_CERT else 1883
INTERVAL_SECONDS = 30


def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def collect_health() -> dict:
    """Minimal health snapshot — stdlib only.

    Extend in a custom role if you need richer metrics (psutil, GPU stats, etc).
    Uses socket.gethostname() not getfqdn() — fqdn can block on misconfigured DNS.
    """
    try:
        with open("/proc/uptime") as f:
            uptime = float(f.read().split()[0])
    except (OSError, ValueError):
        uptime = 0.0
    try:
        with open("/proc/meminfo") as f:
            meminfo = dict(line.split(":", 1) for line in f if ":" in line)
        mem_total_kb = int(meminfo["MemTotal"].strip().split()[0])
        mem_avail_kb = int(meminfo["MemAvailable"].strip().split()[0])
        mem_used_pct = round(100 * (1 - mem_avail_kb / mem_total_kb), 1)
    except (OSError, KeyError, ValueError, ZeroDivisionError):
        mem_used_pct = None
    return {
        "host": HOST,
        "namespace": NAMESPACE,
        "hostname": socket.gethostname(),
        "uptime_seconds": uptime,
        "mem_used_pct": mem_used_pct,
        "ts": _now_iso(),
    }


def on_connect(client, userdata, flags, rc, properties=None):
    if rc == 0:
        # Retained "I'm alive" announcement on every connect.
        client.publish(f"{NAMESPACE}/{HOST}/alive", _now_iso(), retain=True)
    else:
        print(f"MQTT connect failed: rc={rc}", flush=True)


def main() -> None:
    client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2, client_id=f"{NAMESPACE}-{HOST}")
    client.username_pw_set(USER, PASSWORD)
    if CA_CERT:
        # No explicit TLS version pin — auto-negotiate, prefer TLS 1.3.
        client.tls_set(ca_certs=CA_CERT)
    client.on_connect = on_connect

    # Explicit reconnect backoff. Default behavior is reasonable but undocumented;
    # explicit is friendlier for operators tuning per-network.
    client.reconnect_delay_set(min_delay=1, max_delay=120)

    # Last-will: if we die ungracefully, the broker publishes an empty payload
    # to the alive topic (retained). Subscribers treating empty = dead.
    client.will_set(f"{NAMESPACE}/{HOST}/alive", payload="", retain=True)

    client.connect(BROKER, PORT, keepalive=60)
    client.loop_start()

    try:
        while True:
            client.publish(f"{NAMESPACE}/{HOST}/alive", _now_iso(), retain=True)
            client.publish(f"{NAMESPACE}/{HOST}/health", json.dumps(collect_health()))
            time.sleep(INTERVAL_SECONDS)
    finally:
        client.loop_stop()
        client.disconnect()


if __name__ == "__main__":
    main()
